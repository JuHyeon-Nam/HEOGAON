APP_ENV=local
ENABLE_LLM=true
ENABLE_DEMO_FALLBACK=true
ENABLE_GRAPH_RAG=false

# GMS LLM API. GMS_API_KEY is also accepted as a fallback.
LLM_PROVIDER=gms
LLM_API_KEY=
LLM_BASE_URL=https://gms.ssafy.io/gmsapi/api.openai.com/v1
LLM_MODEL=gpt-5.5
LLM_REASONING_EFFORT=low
# minju 파이프라인 GMS 클라이언트가 읽는 값. 비워두면 'minimal'이 되어 gpt-5.5에서 400이 납니다.
GMS_REASONING_EFFORT=low
LLM_MAX_OUTPUT_TOKENS=1024
LLM_TIMEOUT_SECONDS=12

# GraphRAG domain expansion. When disabled or unavailable, catalog fallback is used.
GRAPH_RAG_BASE_URL=
GRAPH_RAG_API_KEY=
GRAPH_RAG_TIMEOUT_SECONDS=8

# 건축물대장 외부 API. 둘 다 있어야 건축물대장 조회가 동작합니다.
# JUSO_API_KEY: 도로명주소 개발자센터 (business.juso.go.kr)
# DATA_GO_KR_SERVICE_KEY: 공공데이터포털 건축물대장정보 서비스 (data.go.kr, BldRgstHubService)
JUSO_API_KEY=
DATA_GO_KR_SERVICE_KEY=
